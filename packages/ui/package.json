{
  "name": "@crypto-currency/ui",
  "private": true,
  "version": "0.0.4",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "description": "The package containing UI components",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sass-embedded": "^1.98.0",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-lib-inject-css": "^2.2.2"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^9.39.4",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0"
  },
  "files": [
    "build"
  ],
  "main": "./build/ui.umd.cjs",
  "module": "./build/ui.js",
  "types": "./build/index.d.ts",
  "exports": {
    ".": {
      "import": "./build/ui.js",
      "require": "./build/ui.umd.cjs",
      "types": "./build/index.d.ts"
    }
  },
  "sideEffects": [
    "**/*.css"
  ]
}
